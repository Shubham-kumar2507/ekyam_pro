# Server
PORT=5000
NODE_ENV=development

# MongoDB
MONGO_URI=mongodb://localhost:27017/ekyam_db

# JWT — Use a strong random string (64+ chars) in production
JWT_SECRET=your_jwt_secret_here_change_me

# Email (Gmail SMTP — use App Passwords, local dev only)
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password_here
REQUIRE_EMAIL_VERIFICATION=true

# Gmail API OAuth2 — see implementation_plan.md for setup steps
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_REFRESH_TOKEN=your_google_refresh_token_here

# Frontend URL (for password reset emails etc.)
FRONTEND_URL=http://localhost:5173

# CORS — comma-separated origins
CORS_ORIGIN=http://localhost:5173

# Cloudinary — sign up free at cloudinary.com
CLOUDINARY_CLOUD_NAME=your_cloud_name_here
CLOUDINARY_API_KEY=your_api_key_here
CLOUDINARY_API_SECRET=your_api_secret_here
