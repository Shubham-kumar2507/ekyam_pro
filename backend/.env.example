# Server
PORT=5000
NODE_ENV=development

# MongoDB
MONGO_URI=mongodb://localhost:27017/ekyam_db

# JWT — Use a strong random string (64+ chars) in production
JWT_SECRET=your_jwt_secret_here_change_me

# Email (Gmail SMTP — use App Passwords)
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password_here
REQUIRE_EMAIL_VERIFICATION=true

# Frontend URL (for password reset emails etc.)
FRONTEND_URL=http://localhost:5173

# CORS — comma-separated origins
CORS_ORIGIN=http://localhost:5173
